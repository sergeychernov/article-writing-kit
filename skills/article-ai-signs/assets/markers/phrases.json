    {
      "id": "language.copulative-avoidance",
      "category": "language",
      "title": "Avoidance of basic copulatives (is/are)",
      "wpShortcut": "WP:AICOPULA",
      "severity": "low",
      "weight": 1,
      "note": "LLMs replace simple 'is/are' with marketing-like verbs (serves as, boasts, features). Weak on its own; do not confuse with past perfect (has been featured).",
      "matchType": "phrase",
      "languages": {
        "en": [
          "serves as a",
          "serves as the",
          "stands as a",
          "stands as the",
          "boasts a",
          "boasts an",
          "features a",
          "offers a",
          "represents a",
          "represents the",
          "refers to the"
        ],
        "ru": [
          "служит",
          "служит краеугольным камнем",
          "выступает в роли",
          "выступает в качестве",
          "выступает символом",
          "представляет собой",
          "является воплощением",
          "является напоминанием",
          "служит напоминанием",
          "играет роль",
          "относится к числу"
        ]
      }
    },
