{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sergeychernov/article-writing-kit/main/skills/article-habr/assets/schemas/habr-hubs.schema.json",
  "title": "Article Habr Hubs Registry",
  "description": "Static registry of Habr thematic hubs parsed from the habr.com chips suggest panel. The article-habr skill validates selected hubs against this list.",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "fetchedAt", "limits", "hubCount", "hubs"],
  "properties": {
    "source": { "type": "string" },
    "fetchedAt": { "type": "string" },
    "note": { "type": "string" },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxHubs", "maxTags"],
      "properties": {
        "maxHubs": { "type": "integer" },
        "maxTags": { "type": "integer" }
      }
    },
    "hubCount": { "type": "integer" },
    "hubs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "title", "multiauthor"],
        "properties": {
          "alias": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "multiauthor": { "type": "boolean" }
        }
      }
    }
  }
}
